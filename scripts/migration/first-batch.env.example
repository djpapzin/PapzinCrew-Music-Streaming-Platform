# First-batch operator template for Path A
# Copy to a local untracked file, for example:
#   cp scripts/migration/first-batch.env.example .migration.first-batch.env
# Then edit and load it with:
#   set -a && source .migration.first-batch.env && set +a

# -----------------------------
# rclone remotes / source batch
# Task 199 source account must be djpapzin@gmail.com
# Confirm rclone auth is pointing at that Google account.
# -----------------------------
GOOGLE_DRIVE_ACCOUNT_EMAIL=djpapzin@gmail.com
DRIVE_REMOTE=gdrive
DRIVE_PATH=PapzinCrewUploads/2026-03-batch-01

B2_REMOTE=b2
B2_BUCKET=papzincrew-music-djpapzin
B2_PREFIX=audio/migration/2026-03-batch-01

# -----------------------------
# rclone performance / retries
# -----------------------------
RCLONE_TRANSFERS=8
RCLONE_CHECKERS=16
RCLONE_RETRIES=12
RCLONE_LOW_LEVEL_RETRIES=32
RCLONE_RETRY_SLEEP=10s
RCLONE_TIMEOUT=5m
RCLONE_CONTIMEOUT=30s
RCLONE_STATS_INTERVAL=30s
RCLONE_BWLIMIT=off

# -----------------------------
# Database target
# Use the real backend DB URL.
# -----------------------------
SQLALCHEMY_DATABASE_URL=postgresql+psycopg2://REPLACE_ME:REPLACE_ME@REPLACE_ME:5432/REPLACE_ME

# -----------------------------
# Public URL base used when inserting mixes.file_path
# Match the real public playback URL for the bucket.
# -----------------------------
B2_PUBLIC_BASE_URL=https://s3.us-east-005.backblazeb2.com/papzincrew-music-djpapzin

# -----------------------------
# Batch artist strategy
# Current importer is safest for one primary artist per batch.
# Choose ONE of the two options below.
# -----------------------------

# Option A: point at an existing artist record id
MIGRATION_ARTIST_ID=

# Option B: if artist id is blank, importer will create/find this name
MIGRATION_DEFAULT_ARTIST_NAME=DJ Papzin

# -----------------------------
# Optional local root for better duration/size metadata
# Leave blank unless you have a local staged mirror of the same batch.
# -----------------------------
MIGRATION_LOCAL_ROOT=
